# personal_portfolio environment variables
# Copy to .env for local use. In production these live as Netlify site
# environment variables. Never commit a real .env.

# --- Database (Neon serverless Postgres) ---
# Neon connection string. Used by the API function and the seed script.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- Session ---
# Random string for signing session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# --- Admin login (for the private admin panel) ---
ADMIN_USERNAME=choose_an_admin_username
ADMIN_PASSWORD=choose_a_strong_admin_password

# --- Email (Resend, for the contact form) ---
# Reuse the same Resend account as DailyQuoteBlaster.
RESEND_API_KEY=your_resend_api_key_here
# Sender: onboarding@resend.dev works for testing and delivers to the
# Resend account owner's address (which is the contact-form recipient).
SENDER_EMAIL=onboarding@resend.dev
# Where contact-form submissions are emailed.
CONTACT_TO_EMAIL=monideep2255@gmail.com
